class Solution {
    public static boolean isPalinArray(int[] n) {
        for (int v : n) {
            int o = v;
            int r = 0;

            while (v > 0) {
                r = r * 10 + v % 10;
                v /= 10;
            }

            if (o!= r) return false;
        }
        return true;
    }
}
