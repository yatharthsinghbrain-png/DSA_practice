class Solution{
    int minSwap(int[]a,int k){
        int g=0;
        for(int x:a){
            if(x<=k)
            g++;
        }
        int b=0;
        for(int i=0;i<g;i++){
            if(a[i]>k)
            b++;
        }
        int ans=b;
        for(int i=g;i<a.length;i++){
            if(a[i-g]>k)b--;
            if(a[i]>k)b++;
            ans=Math.min(ans,b);
        }
        return ans;
    }
}
