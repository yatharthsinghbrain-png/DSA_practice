class Solution {
    public ArrayList<Integer> factorial(int n) {
        ArrayList<Integer> a = new ArrayList<>();
        a.add(1);

        for(int x=2;x<=n;x++){
            int c=0;

            for(int i=a.size()-1;i>=0;i--){
                int p=a.get(i)*x+c;
                a.set(i,p%10);
                c=p/10;
            }

            while(c>0){
                a.add(0,c%10);
                c/=10;
            }
        }

        return a;
    }
}
